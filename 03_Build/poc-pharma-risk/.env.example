# AI Provider: "demo" (free, no key), "openai", or "claude"
VITE_AI_PROVIDER=demo

# Backend API URL (used when backend server is running)
VITE_API_URL=http://localhost:3001/api

# Only needed if VITE_AI_PROVIDER=openai
VITE_OPENAI_API_KEY=

# Only needed if VITE_AI_PROVIDER=claude
VITE_CLAUDE_API_KEY=
